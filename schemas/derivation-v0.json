{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://laycache.dev/schemas/derivation-v0.json",
  "title": "LayCache Derivation v0",
  "description": "派生对象，代表从Event派生的AI生成内容",
  "type": "object",
  "required": ["id", "event_id", "type", "content", "model", "model_version", "input_hashes"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$",
      "description": "UUID v4"
    },
    "event_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$",
      "description": "关联的Event ID"
    },
    "type": {
      "type": "string",
      "enum": ["summary", "classify", "extract"],
      "description": "派生类型"
    },
    "content": {
      "type": "string",
      "description": "派生内容"
    },
    "model": {
      "type": "string",
      "description": "使用的模型（如gpt-4）"
    },
    "model_version": {
      "type": "string",
      "description": "模型版本"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "置信度（0.0-1.0）"
    },
    "input_hashes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      },
      "description": "输入Event的hash数组"
    }
  }
}
